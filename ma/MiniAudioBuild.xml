<xml>
	<set name="PROJECT_DIR" value="${this_dir}" />

	<files id='haxe'>
		<compilervalue name="-I" value="${PROJECT_DIR}/" />
		<compilervalue name="-I" value="${PROJECT_DIR}/include" />
	</files>

	<target id='haxe' tool='linker' toolid='exe' if='windows'>
		<lib name='${PROJECT_DIR}/lib/windows64/libogg.lib' if='HXCPP_M64' />
		<lib name='${PROJECT_DIR}/lib/windows64/opus.lib' if='HXCPP_M64' />
		<lib name='${PROJECT_DIR}/lib/windows64/opusfile.lib' if='HXCPP_M64' />
		<lib name='${PROJECT_DIR}/lib/windows32/libogg.lib' if='HXCPP_M32' />
		<lib name='${PROJECT_DIR}/lib/windows32/opus.lib' if='HXCPP_M32' />
		<lib name='${PROJECT_DIR}/lib/windows32/opusfile.lib' if='HXCPP_M32' />
	</target> 
	<target id='haxe' tool='linker' if='mac'>
		<lib name='${PROJECT_DIR}/lib/Mac64/libogg.a' if='HXCPP_M64' />
		<lib name='${PROJECT_DIR}/lib/Mac64/libopus.a' if='HXCPP_M64' />
		<lib name='${PROJECT_DIR}/lib/Mac64/libopusfile.a' if='HXCPP_M64' />
	</target>
</xml>
